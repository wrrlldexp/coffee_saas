{
  "name": "takt-saas",
  "version": "0.1.0",
  "description": "takt — SaaS platform for cafe management",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:backup": "bash scripts/db-backup.sh",
    "db:restore": "bash scripts/db-restore.sh",
    "zenstack:generate": "zenstack generate",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:sqlite": "tsx scripts/migrate-sqlite.ts",
    "migrate:sqlite:dry": "tsx scripts/migrate-sqlite.ts --dry-run"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@types/compression": "^1.8.1",
    "@types/multer": "^2.2.0",
    "@zenstackhq/runtime": "^2.22.3",
    "better-auth": "1.6.23",
    "bullmq": "5.79.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.6.1",
    "multer": "^2.2.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.0",
    "@types/supertest": "^6.0.2",
    "better-sqlite3": "^12.11.1",
    "eslint": "^9.28.0",
    "prisma": "7.8.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.0",
    "zenstack": "2.22.3"
  }
}
